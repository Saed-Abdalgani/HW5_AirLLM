# Environment configuration — copy to .env and fill in real values.
# NEVER commit the actual .env file.

# ── HuggingFace ───────────────────────────────────────────────────────────────
# Personal access token (needed for gated models such as Llama-3).
HF_TOKEN=hf_YOUR_TOKEN_HERE

# Rate-limit cap for HuggingFace Hub calls (requests per minute).
HF_RATE_LIMIT_PER_MIN=30

# ── Models ────────────────────────────────────────────────────────────────────
# Primary "large" model used for baseline-fail + AirLLM-success runs.
MODEL_ID=Qwen/Qwen2.5-3B-Instruct

# Tiny model for pipeline sanity-check (transformers-cpu backend).
SANITY_MODEL_ID=Qwen/Qwen2.5-0.5B-Instruct

# Ollama model tag used for the B1 (Ollama) sanity run.
OLLAMA_SANITY_MODEL=qwen2:0.5b

# ── Benchmark parameters ──────────────────────────────────────────────────────
# Prompt sent to every backend (keep short for reproducibility).
PROMPT=Explain virtual memory in one sentence.

# Max new tokens to generate (tiny to keep runtime bounded on slow hardware).
MAX_NEW_TOKENS=16

# Random seed for reproducible generation.
SEED=42

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── AirLLM ───────────────────────────────────────────────────────────────────
# Directory where AirLLM writes per-layer weight shards on first run.
SHARDS_PATH=data/shards

# ── Safety / watchdog ────────────────────────────────────────────────────────
# Abort a run if process RSS exceeds this limit (MB).
MEMORY_CEILING_MB=3500

# Hard timeout per backend run (seconds). 3600 = 1 hour.
RUN_TIMEOUT_S=3600

# ── Metrics ──────────────────────────────────────────────────────────────────
# How often MemoryMonitor samples psutil RSS (seconds).
SAMPLE_INTERVAL_S=0.25

# ── Output directories ────────────────────────────────────────────────────────
RESULTS_DIR=results
ASSETS_DIR=assets
